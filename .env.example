# Application Configuration
APP_NAME="AI Smart Campus Event Registration Agent"
ENV=development
DEBUG=True

# Asynchronous MongoDB Atlas Connection String
# Replace with your actual MongoDB Atlas cluster credentials in .env
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/?retryWrites=true&w=majority
DATABASE_NAME=campus_agent_db

# Security & Tokens Configuration
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET=your_super_secret_jwt_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google Gemini API Credentials
# Get your API key from Google AI Studio
GEMINI_API_KEY=AIzaSy...

# Logger Configuration
LOG_LEVEL=INFO

# Mailer Configuration for Ticket Delivery
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@campus.edu
